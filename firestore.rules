rules_version = '2';

// Firestore Security Rules for PlayerPath
// Deploy: firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================================================
    // HELPER FUNCTIONS
    // ========================================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userID) {
      return request.auth.uid == userID;
    }

    // Coaching access requires Pro tier (add-on model removed 3/1/26)
    function hasCoachingAccess() {
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return user.subscriptionTier == "pro";
    }

    function canAccessFolder(folderID) {
      let folder = get(/databases/$(database)/documents/sharedFolders/$(folderID)).data;
      return request.auth.uid == folder.ownerAthleteID
          || request.auth.uid in folder.sharedWithCoachIDs;
    }

    function hasPermission(folderID, permission) {
      let folder = get(/databases/$(database)/documents/sharedFolders/$(folderID)).data;
      let perms = folder.permissions[request.auth.uid];
      return request.auth.uid == folder.ownerAthleteID
          || (permission == "upload"   && perms.canUpload  == true)
          || (permission == "comment"  && perms.canComment == true)
          || (permission == "delete"   && perms.canDelete  == true);
    }

    function isInvitationNotExpired(expiresAt) {
      return request.time < expiresAt;
    }

    // ========================================================================
    // USER PROFILES
    // ========================================================================

    match /users/{userID} {
      // Only the profile owner can read their own document
      allow read: if isAuthenticated() && isOwner(userID);

      // Users can create their own profile on signup
      allow create: if isAuthenticated() && isOwner(userID);

      // Users can update their own profile, but cannot change their role.
      // subscriptionTier and coachSubscriptionTier are written by the client from StoreKit
      // receipts — this is safe because StoreKit is the source of truth and the tier only
      // unlocks UI, not server-side data access.
      allow update: if isAuthenticated()
                    && isOwner(userID)
                    && request.resource.data.role == resource.data.role;

      // Profiles are deleted via Firebase Auth / Cloud Functions, not directly
      allow delete: if false;

      // ======================================================================
      // ATHLETES SUBCOLLECTION
      // ======================================================================

      match /athletes/{athleteID} {
        allow read:   if isAuthenticated() && isOwner(userID);
        // Path-based ownership (isOwner) is sufficient — no redundant field check needed
        allow create: if isAuthenticated() && isOwner(userID);
        allow update: if isAuthenticated() && isOwner(userID);
        allow delete: if isAuthenticated() && isOwner(userID);
      }

      // ======================================================================
      // SEASONS SUBCOLLECTION
      // ======================================================================

      match /seasons/{seasonID} {
        allow read:   if isAuthenticated() && isOwner(userID);
        allow create: if isAuthenticated() && isOwner(userID);
        allow update: if isAuthenticated() && isOwner(userID);
        allow delete: if isAuthenticated() && isOwner(userID);
      }

      // ======================================================================
      // GAMES SUBCOLLECTION
      // ======================================================================

      match /games/{gameID} {
        allow read:   if isAuthenticated() && isOwner(userID);
        allow create: if isAuthenticated() && isOwner(userID);
        allow update: if isAuthenticated() && isOwner(userID);
        allow delete: if isAuthenticated() && isOwner(userID);
      }

      // ======================================================================
      // PRACTICES SUBCOLLECTION
      // ======================================================================

      match /practices/{practiceID} {
        allow read:   if isAuthenticated() && isOwner(userID);
        allow create: if isAuthenticated() && isOwner(userID);
        allow update: if isAuthenticated() && isOwner(userID);
        allow delete: if isAuthenticated() && isOwner(userID);

        // Practice notes subcollection
        match /notes/{noteID} {
          allow read:   if isAuthenticated() && isOwner(userID);
          allow create: if isAuthenticated() && isOwner(userID);
          allow update: if isAuthenticated() && isOwner(userID);
          allow delete: if isAuthenticated() && isOwner(userID);
        }
      }

      // ======================================================================
      // COACHES SUBCOLLECTION (per-athlete)
      // ======================================================================

      match /athletes/{athleteID}/coaches/{coachID} {
        allow read:   if isAuthenticated() && isOwner(userID);
        allow create: if isAuthenticated() && isOwner(userID);
        allow update: if isAuthenticated() && isOwner(userID);
        allow delete: if isAuthenticated() && isOwner(userID);
      }
    }

    // ========================================================================
    // PHOTOS
    // ========================================================================

    match /photos/{photoID} {
      allow read:   if isAuthenticated() && resource.data.uploadedBy == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uploadedBy == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uploadedBy == request.auth.uid
                    && request.resource.data.uploadedBy == resource.data.uploadedBy;
      allow delete: if isAuthenticated() && resource.data.uploadedBy == request.auth.uid;
    }

    // ========================================================================
    // SHARED FOLDERS
    // ========================================================================

    match /sharedFolders/{folderID} {
      allow read:   if isAuthenticated() && canAccessFolder(folderID);

      // Only users with coaching access can create folders
      allow create: if isAuthenticated()
                    && hasCoachingAccess()
                    && request.resource.data.ownerAthleteID == request.auth.uid;

      // Only the folder owner can update or delete
      allow update: if isAuthenticated()
                    && resource.data.ownerAthleteID == request.auth.uid;
      allow delete: if isAuthenticated()
                    && resource.data.ownerAthleteID == request.auth.uid;
    }

    // ========================================================================
    // VIDEOS
    // ========================================================================

    match /videos/{videoID} {
      // Read: personal video owner OR shared folder member
      allow read: if isAuthenticated() && (
        resource.data.uploadedBy == request.auth.uid ||
        ('sharedFolderID' in resource.data && canAccessFolder(resource.data.sharedFolderID))
      );

      // Create: personal athlete video (no sharedFolderID, uploader is owner)
      //         OR shared folder video (uploader has folder upload permission)
      allow create: if isAuthenticated() && (
        (request.resource.data.uploadedBy == request.auth.uid &&
         !('sharedFolderID' in request.resource.data)) ||
        (hasPermission(request.resource.data.sharedFolderID, "upload") &&
         request.resource.data.uploadedBy == request.auth.uid)
      );

      // Only the uploader can update their own video.
      // uploadedBy is immutable; all other fields are user-controlled.
      allow update: if isAuthenticated()
                    && resource.data.uploadedBy == request.auth.uid
                    && request.resource.data.uploadedBy == resource.data.uploadedBy;

      // Delete: uploader can delete their own videos; folder members with delete permission
      allow delete: if isAuthenticated() && (
        resource.data.uploadedBy == request.auth.uid ||
        ('sharedFolderID' in resource.data &&
         canAccessFolder(resource.data.sharedFolderID) &&
         hasPermission(resource.data.sharedFolderID, "delete"))
      );

      // ======================================================================
      // VIDEO COMMENTS SUBCOLLECTION (unified athlete + coach thread)
      // ======================================================================

      match /comments/{commentID} {
        // Read: the video owner OR any coach sharing the folder
        allow read: if isAuthenticated() && (
          get(/databases/$(database)/documents/videos/$(videoID)).data.uploadedBy == request.auth.uid
          || ('sharedFolderID' in get(/databases/$(database)/documents/videos/$(videoID)).data
              && canAccessFolder(
                   get(/databases/$(database)/documents/videos/$(videoID)).data.sharedFolderID
                 ))
        );

        // Create: authenticated user posting as themselves
        allow create: if isAuthenticated()
                      && request.resource.data.authorId == request.auth.uid;

        // Update/delete: only the comment author
        allow update, delete: if isAuthenticated()
                               && resource.data.authorId == request.auth.uid;
      }

      // ======================================================================
      // VIDEO ANNOTATIONS SUBCOLLECTION
      // ======================================================================

      match /annotations/{annotationID} {
        allow read: if isAuthenticated()
                    && canAccessFolder(
                         get(/databases/$(database)/documents/videos/$(videoID)).data.sharedFolderID
                       );

        allow create: if isAuthenticated()
                      && request.resource.data.userID == request.auth.uid
                      && hasPermission(
                           get(/databases/$(database)/documents/videos/$(videoID)).data.sharedFolderID,
                           "comment"
                         );

        // Users can edit their own annotations
        allow update: if isAuthenticated()
                      && resource.data.userID == request.auth.uid;

        // Users can delete their own annotations; folder owner can delete any
        allow delete: if isAuthenticated()
                      && (resource.data.userID == request.auth.uid
                          || get(/databases/$(database)/documents/sharedFolders/$(
                               get(/databases/$(database)/documents/videos/$(videoID)).data.sharedFolderID
                             )).data.ownerAthleteID == request.auth.uid);
      }
    }

    // ========================================================================
    // NOTIFICATIONS
    // ========================================================================

    match /notifications/{userID}/items/{itemID} {
      // Only the recipient can read their notifications
      allow read:   if isAuthenticated() && isOwner(userID);

      // Any authenticated user can write a notification to another user
      // (coaches notify athletes on upload/comment, athletes notify coaches on acceptance)
      allow create: if isAuthenticated();

      // Only the recipient can mark notifications as read
      allow update: if isAuthenticated() && isOwner(userID);

      // Only the recipient can delete notifications
      allow delete: if isAuthenticated() && isOwner(userID);
    }

    // ========================================================================
    // COACH ACCESS REVOCATIONS
    // ========================================================================

    match /coach_access_revocations/{revocationID} {
      // Only the athlete who created the revocation can read it
      allow read:   if isAuthenticated()
                    && resource.data.athleteID == request.auth.uid;

      // Folder owners create revocations referencing themselves
      allow create: if isAuthenticated()
                    && request.resource.data.athleteID == request.auth.uid;

      // Immutable after creation (email tracking is server-side)
      allow update: if false;

      // Only the creating athlete can delete
      allow delete: if isAuthenticated()
                    && resource.data.athleteID == request.auth.uid;
    }

    // ========================================================================
    // INVITATIONS
    // ========================================================================

    match /invitations/{invitationID} {
      // Athletes can always read their own invitations (including expired, for cleanup)
      // Coaches can only read non-expired invitations sent to their email
      allow read: if isAuthenticated() && (
        resource.data.athleteID == request.auth.uid ||
        (resource.data.coachEmail == request.auth.token.email &&
         isInvitationNotExpired(resource.data.expiresAt))
      );

      // Only users with coaching access can send invitations
      allow create: if isAuthenticated()
                    && hasCoachingAccess()
                    && request.resource.data.athleteID == request.auth.uid
                    && request.resource.data.keys().hasAll(['expiresAt'])
                    && isInvitationNotExpired(request.resource.data.expiresAt);

      // Athlete can cancel; coach can accept/decline — only while not expired
      allow update: if isAuthenticated()
                    && isInvitationNotExpired(resource.data.expiresAt)
                    && (resource.data.athleteID == request.auth.uid ||
                        resource.data.coachEmail == request.auth.token.email);

      // Only the sending athlete can delete (including expired invitations)
      allow delete: if isAuthenticated()
                    && resource.data.athleteID == request.auth.uid;
    }

    // ========================================================================
    // DENY ALL OTHER COLLECTIONS
    // ========================================================================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
