rules_version = '2';

// Firestore Security Rules for PlayerPath
// Deploy: firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================================================
    // HELPER FUNCTIONS
    // ========================================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userID) {
      return request.auth.uid == userID;
    }

    // Checks if the requesting user has a Pro (or higher) athlete subscription tier.
    // Used to gate shared folder and invitation creation.
    // Uses list check so future tiers above Pro are automatically included.
    function hasProTier() {
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return user != null && user.subscriptionTier in ["pro"];
    }

    // Checks if the requesting user is a coach with a valid subscription tier.
    // Requires role == 'coach' to prevent athletes from impersonating coaches.
    // Whitelist prevents arbitrary strings from granting access.
    function hasCoachTier() {
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return user != null && user.role == 'coach'
             && user.coachSubscriptionTier in [
                  'coach_free', 'coach_instructor', 'coach_pro_instructor', 'coach_academy'
                ];
    }

    // Checks if the requesting user is the owner of a shared folder.
    function isFolderOwner(folderID) {
      let folder = get(/databases/$(database)/documents/sharedFolders/$(folderID)).data;
      return request.auth.uid == folder.ownerAthleteID;
    }

    function canAccessFolder(folderID) {
      let folder = get(/databases/$(database)/documents/sharedFolders/$(folderID)).data;
      return request.auth.uid == folder.ownerAthleteID
          || request.auth.uid in folder.sharedWithCoachIDs;
    }

    function hasPermission(folderID, permission) {
      let folder = get(/databases/$(database)/documents/sharedFolders/$(folderID)).data;
      let perms = folder.permissions[request.auth.uid];
      return request.auth.uid == folder.ownerAthleteID
          || (perms != null && permission == "upload"   && perms.canUpload  == true)
          || (perms != null && permission == "comment"  && perms.canComment == true)
          || (perms != null && permission == "delete"   && perms.canDelete  == true);
    }

    function isInvitationNotExpired(expiresAt) {
      return request.time < expiresAt;
    }

    // Validates expiresAt is between now and 33 days from now (allows ~30 day invitations
    // with a small buffer for clock skew, but prevents arbitrarily long expiration)
    function isExpirationInRange(expiresAt) {
      return expiresAt > request.time
             && expiresAt < request.time + duration.value(33, 'd');
    }

    // Checks if a coach is ONLY removing themselves from a folder (self-revocation).
    // Used for the coach downgrade flow where the coach must reduce their athlete count.
    function isCoachLeavingFolder() {
      return request.auth.uid in resource.data.sharedWithCoachIDs
          && !(request.auth.uid in request.resource.data.sharedWithCoachIDs)
          // Exactly one coach removed, none added
          && request.resource.data.sharedWithCoachIDs.size() == resource.data.sharedWithCoachIDs.size() - 1
          // ownerAthleteID must not change
          && request.resource.data.ownerAthleteID == resource.data.ownerAthleteID
          // folder name must not change
          && request.resource.data.name == resource.data.name
          // Only allowed fields: sharedWithCoachIDs, permissions, updatedAt
          && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['sharedWithCoachIDs', 'sharedWithCoachNames', 'permissions', 'updatedAt']);
    }

    // Checks if a coach is ONLY incrementing or decrementing videoCount on a folder
    // they already have access to. Used to allow batched video create/delete operations.
    // Delta is bounded to ±10 to prevent abuse (single batch won't exceed this).
    function isCoachUpdatingVideoCount() {
      return request.auth.uid in resource.data.sharedWithCoachIDs
          && request.resource.data.ownerAthleteID == resource.data.ownerAthleteID
          && request.resource.data.name == resource.data.name
          && request.resource.data.sharedWithCoachIDs == resource.data.sharedWithCoachIDs
          && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['videoCount', 'updatedAt'])
          && request.resource.data.videoCount >= 0
          && request.resource.data.videoCount <= resource.data.videoCount + 10
          && request.resource.data.videoCount >= resource.data.videoCount - 10;
    }

    // Helper to get the parent video's data (used by comments/annotations subcollections)
    function getVideoData(videoID) {
      return get(/databases/$(database)/documents/videos/$(videoID)).data;
    }

    // ========================================================================
    // USER PROFILES
    // ========================================================================

    match /users/{userID} {
      // Only the profile owner can read their own document
      allow read: if isAuthenticated() && isOwner(userID);

      // Users can create their own profile on signup.
      // subscriptionTier must be "free" on creation — upgrades go through
      // the syncSubscriptionTier Cloud Function after receipt validation.
      // coachSubscriptionTier must be absent (athletes) or "coach_free" (coaches).
      allow create: if isAuthenticated()
                    && isOwner(userID)
                    && request.resource.data.subscriptionTier == "free"
                    && (!('coachSubscriptionTier' in request.resource.data)
                        || request.resource.data.coachSubscriptionTier == "coach_free");

      // Users can update their own profile, but cannot change their role,
      // subscription tiers, tier source, or coach athlete count. These fields
      // are managed exclusively by Cloud Functions (admin SDK).
      allow update: if isAuthenticated()
                    && isOwner(userID)
                    && request.resource.data.role == resource.data.role
                    && request.resource.data.subscriptionTier == resource.data.subscriptionTier
                    && request.resource.data.coachSubscriptionTier == resource.data.coachSubscriptionTier
                    && (!('coachAthleteCount' in resource.data)
                        || request.resource.data.coachAthleteCount == resource.data.coachAthleteCount)
                    && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['athleteTierSource']);

      // Profiles are deleted via Firebase Auth / Cloud Functions, not directly
      allow delete: if false;

      // ======================================================================
      // ATHLETES SUBCOLLECTION
      // ======================================================================

      match /athletes/{athleteID} {
        allow read:   if isAuthenticated() && isOwner(userID);
        // Athlete creation is gated by tier-based limits.
        // Free: 1, Plus: 3, Pro: 5.  Enforced via Cloud Function
        // (athleteCountCheck) because Firestore rules cannot count
        // subcollection documents.  Client-side checks in AddAthleteView
        // provide the primary UX gate; the function acts as a backstop.
        allow create: if isAuthenticated() && isOwner(userID);
        allow update: if isAuthenticated() && isOwner(userID);
        allow delete: if isAuthenticated() && isOwner(userID);
      }

      // ======================================================================
      // SEASONS SUBCOLLECTION
      // ======================================================================

      match /seasons/{seasonID} {
        allow read:   if isAuthenticated() && isOwner(userID);
        allow create: if isAuthenticated() && isOwner(userID);
        allow update: if isAuthenticated() && isOwner(userID);
        allow delete: if isAuthenticated() && isOwner(userID);
      }

      // ======================================================================
      // GAMES SUBCOLLECTION
      // ======================================================================

      match /games/{gameID} {
        allow read:   if isAuthenticated() && isOwner(userID);
        allow create: if isAuthenticated() && isOwner(userID);
        allow update: if isAuthenticated() && isOwner(userID);
        allow delete: if isAuthenticated() && isOwner(userID);
      }

      // ======================================================================
      // PRACTICES SUBCOLLECTION
      // ======================================================================

      match /practices/{practiceID} {
        allow read:   if isAuthenticated() && isOwner(userID);
        allow create: if isAuthenticated() && isOwner(userID);
        allow update: if isAuthenticated() && isOwner(userID);
        allow delete: if isAuthenticated() && isOwner(userID);

        // Practice notes subcollection
        match /notes/{noteID} {
          allow read:   if isAuthenticated() && isOwner(userID);
          allow create: if isAuthenticated() && isOwner(userID);
          allow update: if isAuthenticated() && isOwner(userID);
          allow delete: if isAuthenticated() && isOwner(userID);
        }
      }

      // ======================================================================
      // COACHES SUBCOLLECTION (per-athlete)
      // ======================================================================

      match /athletes/{athleteID}/coaches/{coachID} {
        allow read:   if isAuthenticated() && isOwner(userID);
        allow create: if isAuthenticated() && isOwner(userID);
        allow update: if isAuthenticated() && isOwner(userID);
        allow delete: if isAuthenticated() && isOwner(userID);
      }
    }

    // ========================================================================
    // PHOTOS
    // ========================================================================

    match /photos/{photoID} {
      allow read:   if isAuthenticated() && resource.data.uploadedBy == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uploadedBy == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uploadedBy == request.auth.uid
                    && request.resource.data.uploadedBy == resource.data.uploadedBy;
      allow delete: if isAuthenticated() && resource.data.uploadedBy == request.auth.uid;
    }

    // ========================================================================
    // SHARED FOLDERS
    // ========================================================================

    match /sharedFolders/{folderID} {
      allow read:   if isAuthenticated()
                    && (resource.data.ownerAthleteID == request.auth.uid
                        || request.auth.uid in resource.data.sharedWithCoachIDs);

      // Only athletes with Pro tier can create shared folders
      allow create: if isAuthenticated()
                    && hasProTier()
                    && request.resource.data.ownerAthleteID == request.auth.uid;

      // Folder owner can update anything. A coach can also update the folder
      // when leaving a folder (removing themselves during downgrade), or
      // when updating video count after upload/delete.
      // Note: coach folder joining is handled by Cloud Functions (Admin SDK),
      // not client-side writes, so no rule is needed for that path.
      allow update: if isAuthenticated()
                    && (resource.data.ownerAthleteID == request.auth.uid
                        || isCoachLeavingFolder()
                        || isCoachUpdatingVideoCount());
      allow delete: if isAuthenticated()
                    && resource.data.ownerAthleteID == request.auth.uid;
    }

    // ========================================================================
    // VIDEOS
    // ========================================================================

    match /videos/{videoID} {
      // Read: personal video owner OR shared folder member with valid tier
      // Folder owner must have Pro tier; coaches must have any coach tier.
      allow read: if isAuthenticated() && (
        resource.data.uploadedBy == request.auth.uid ||
        ('sharedFolderID' in resource.data && canAccessFolder(resource.data.sharedFolderID)
         && (isFolderOwner(resource.data.sharedFolderID) || hasCoachTier()))
      );

      // Create: personal athlete video (no sharedFolderID, uploader is owner)
      //         OR shared folder video (uploader has permission; coaches must have active subscription)
      // Visibility must be "shared" or "private" if specified.
      // uploadStatus "pending" is allowed for metadata-first uploads (firebaseStorageURL may be empty).
      allow create: if isAuthenticated() && (
        (request.resource.data.uploadedBy == request.auth.uid &&
         !('sharedFolderID' in request.resource.data)) ||
        (hasPermission(request.resource.data.sharedFolderID, "upload") &&
         request.resource.data.uploadedBy == request.auth.uid &&
         (isFolderOwner(request.resource.data.sharedFolderID) ? hasProTier() : hasCoachTier()))
      ) && (!('visibility' in request.resource.data) || request.resource.data.visibility in ['shared', 'private']);

      // Only the uploader can update their own video.
      // uploadedBy and sharedFolderID are immutable — prevents moving a video
      // into a folder the uploader doesn't own.
      // For shared-folder videos, the uploader must still have folder access —
      // prevents removed coaches from modifying videos they previously uploaded.
      allow update: if isAuthenticated()
                    && resource.data.uploadedBy == request.auth.uid
                    && request.resource.data.uploadedBy == resource.data.uploadedBy
                    && (!('sharedFolderID' in resource.data) || request.resource.data.sharedFolderID == resource.data.sharedFolderID)
                    && (!('sharedFolderID' in resource.data) || canAccessFolder(resource.data.sharedFolderID));

      // Delete: uploader can delete their own videos; folder members with delete permission
      allow delete: if isAuthenticated() && (
        resource.data.uploadedBy == request.auth.uid ||
        ('sharedFolderID' in resource.data &&
         canAccessFolder(resource.data.sharedFolderID) &&
         hasPermission(resource.data.sharedFolderID, "delete"))
      );

      // ======================================================================
      // VIDEO COMMENTS SUBCOLLECTION (unified athlete + coach thread)
      // ======================================================================

      match /comments/{commentID} {
        // Read: the video owner OR any coach sharing the folder
        allow read: if isAuthenticated() && (
          getVideoData(videoID).uploadedBy == request.auth.uid
          || ('sharedFolderID' in getVideoData(videoID)
              && canAccessFolder(getVideoData(videoID).sharedFolderID))
        );

        // Create: authenticated user posting as themselves with required fields
        // Must have access to the video (uploader or folder member)
        allow create: if isAuthenticated()
                      && request.resource.data.authorId == request.auth.uid
                      && request.resource.data.keys().hasAll(['authorId', 'content', 'createdAt'])
                      && (getVideoData(videoID).uploadedBy == request.auth.uid
                          || ('sharedFolderID' in getVideoData(videoID)
                              && canAccessFolder(getVideoData(videoID).sharedFolderID)));

        // Update: only the comment author, authorId must remain unchanged
        allow update: if isAuthenticated()
                      && resource.data.authorId == request.auth.uid
                      && request.resource.data.authorId == resource.data.authorId;

        // Delete: comment author or folder owner (moderation)
        allow delete: if isAuthenticated()
                      && (resource.data.authorId == request.auth.uid
                          || ('sharedFolderID' in getVideoData(videoID)
                              && isFolderOwner(getVideoData(videoID).sharedFolderID)));
      }

      // ======================================================================
      // VIDEO ANNOTATIONS SUBCOLLECTION
      // ======================================================================

      match /annotations/{annotationID} {
        // Read: folder owner OR shared folder member (annotations only exist on shared videos)
        allow read: if isAuthenticated()
                    && 'sharedFolderID' in getVideoData(videoID)
                    && canAccessFolder(getVideoData(videoID).sharedFolderID);

        // Create: user posting as themselves with comment permission and required fields.
        // Video owner (athlete) can always annotate; coaches need an active subscription.
        allow create: if isAuthenticated()
                      && request.resource.data.userID == request.auth.uid
                      && request.resource.data.keys().hasAll(['userID', 'text', 'timestamp'])
                      && 'sharedFolderID' in getVideoData(videoID)
                      && hasPermission(getVideoData(videoID).sharedFolderID, "comment")
                      && (isFolderOwner(getVideoData(videoID).sharedFolderID)
                          || hasCoachTier());

        // Users can edit their own annotations, userID must remain unchanged
        allow update: if isAuthenticated()
                      && resource.data.userID == request.auth.uid
                      && request.resource.data.userID == resource.data.userID;

        // Users can delete their own annotations; folder owner can delete any
        allow delete: if isAuthenticated()
                      && (resource.data.userID == request.auth.uid
                          || get(/databases/$(database)/documents/sharedFolders/$(
                               getVideoData(videoID).sharedFolderID
                             )).data.ownerAthleteID == request.auth.uid);
      }
    }

    // ========================================================================
    // NOTIFICATIONS
    // ========================================================================

    // Parent notification document — only the owner can delete (GDPR cleanup)
    match /notifications/{userID} {
      allow read:   if isAuthenticated() && isOwner(userID);
      allow create: if false;
      allow update: if false;
      allow delete: if isAuthenticated() && isOwner(userID);
    }

    match /notifications/{userID}/items/{itemID} {
      // Only the recipient can read their notifications
      allow read:   if isAuthenticated() && isOwner(userID);

      // Authenticated users can create notifications for a specific recipient.
      // Must identify themselves as sender, include required fields, use a valid
      // notification type, AND prove a relationship with the recipient via a shared
      // folder or invitation. This prevents arbitrary users from spamming notifications.
      allow create: if isAuthenticated()
                    && request.resource.data.senderID == request.auth.uid
                    && request.resource.data.keys().hasAll(['senderID', 'type', 'title', 'body', 'createdAt', 'isRead'])
                    && request.resource.data.isRead == false
                    && request.resource.data.type in [
                         'new_video', 'coach_comment', 'invitation_received',
                         'invitation_accepted', 'access_revoked', 'access_lapsed'
                       ]
                    && (
                      // Branch 1: Has explicit folderID field — verify sender has folder access
                      // (covers: coach_comment, drill_card notifications)
                      ('folderID' in request.resource.data
                        && canAccessFolder(request.resource.data.folderID))
                      ||
                      // Branch 2: targetType is folder — verify sender has folder access
                      // (covers: new_video, invitation_accepted, access_revoked by owner, access_lapsed)
                      (request.resource.data.targetType == 'folder'
                        && canAccessFolder(request.resource.data.targetID))
                      ||
                      // Branch 3: Access removal where sender was just removed from folder.
                      // Weaker check (folder exists) because sender already left the folder.
                      // Risk: someone who knows a folder UUID could send this type. Mitigated
                      // by UUIDs being unguessable and senderID being verified above.
                      // (covers: access_revoked by coach during downgrade)
                      (request.resource.data.type in ['access_revoked', 'access_lapsed']
                        && 'targetID' in request.resource.data
                        && exists(/databases/$(database)/documents/sharedFolders/$(request.resource.data.targetID)))
                      ||
                      // Branch 4: Invitation-targeted — verify the invitation exists
                      // (covers: invitation_received, invitation_accepted without folder)
                      (request.resource.data.targetType == 'invitation'
                        && request.resource.data.type in ['invitation_received', 'invitation_accepted']
                        && exists(/databases/$(database)/documents/invitations/$(request.resource.data.targetID)))
                    );

      // Only the recipient can update, and only to mark as read.
      // Prevents rewriting sender, type, title, body, etc.
      allow update: if isAuthenticated() && isOwner(userID)
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['isRead']);

      // Only the recipient can delete notifications
      allow delete: if isAuthenticated() && isOwner(userID);
    }

    // ========================================================================
    // COACH ACCESS REVOCATIONS
    // ========================================================================

    match /coach_access_revocations/{revocationID} {
      // The athlete or the coach referenced in the revocation can read it
      allow read:   if isAuthenticated()
                    && (resource.data.athleteID == request.auth.uid
                        || resource.data.coachID == request.auth.uid);

      // Athletes create revocations when removing a coach from their folder.
      // Coaches create revocations during downgrade (self-removal from folders).
      // Must reference a valid folder where the creator is a party.
      allow create: if isAuthenticated()
                    && 'folderID' in request.resource.data
                    && (
                      // Athlete removing a coach: must be folder owner
                      (request.resource.data.athleteID == request.auth.uid
                        && isFolderOwner(request.resource.data.folderID))
                      ||
                      // Coach self-removing during downgrade: must currently be in folder
                      // (batch write evaluates rules against pre-commit state)
                      (request.resource.data.coachID == request.auth.uid
                        && canAccessFolder(request.resource.data.folderID))
                    );

      // Immutable after creation (email tracking is server-side)
      allow update: if false;

      // The creating party (athlete or coach) can delete their own revocation
      allow delete: if isAuthenticated()
                    && (resource.data.athleteID == request.auth.uid
                        || resource.data.coachID == request.auth.uid);
    }

    // ========================================================================
    // ========================================================================
    // COACH TEMPLATES (Quick Cues)
    // ========================================================================

    // Parent document for coach templates (may be auto-created by Firestore)
    match /coachTemplates/{coachID} {
      allow read:   if isAuthenticated() && isOwner(coachID);
      allow write:  if false; // Managed implicitly; no direct writes needed
    }

    match /coachTemplates/{coachID}/quickCues/{cueID} {
      // Only the owning coach can read/write their quick cues
      allow read:   if isAuthenticated() && isOwner(coachID);
      allow create: if isAuthenticated() && isOwner(coachID);
      allow update: if isAuthenticated() && isOwner(coachID);
      allow delete: if isAuthenticated() && isOwner(coachID);
    }

    // ========================================================================
    // DRILL CARDS (subcollection of videos)
    // ========================================================================

    match /videos/{videoID}/drillCards/{cardID} {
      // Coach who created it OR folder member can read
      allow read: if isAuthenticated()
                  && ('sharedFolderID' in getVideoData(videoID)
                      ? canAccessFolder(getVideoData(videoID).sharedFolderID)
                      : resource.data.coachID == request.auth.uid);

      // Coach can create drill cards on videos they have access to
      // Must have folder access and an active coach subscription
      allow create: if isAuthenticated()
                    && request.resource.data.coachID == request.auth.uid
                    && hasCoachTier()
                    && ('sharedFolderID' in getVideoData(videoID)
                        && canAccessFolder(getVideoData(videoID).sharedFolderID));

      // Only the creating coach can update/delete; coachID is immutable
      allow update: if isAuthenticated()
                    && resource.data.coachID == request.auth.uid
                    && request.resource.data.coachID == resource.data.coachID;
      allow delete: if isAuthenticated()
                    && resource.data.coachID == request.auth.uid;
    }

    // ========================================================================
    // VIDEO ACCESS LOGS (subcollection of videos)
    // ========================================================================

    match /videos/{videoID}/access_logs/{logID} {
      // Read: video uploader or coaches with folder access (for engagement tracking)
      allow read: if isAuthenticated()
                  && ('sharedFolderID' in getVideoData(videoID)
                      ? (canAccessFolder(getVideoData(videoID).sharedFolderID)
                         || getVideoData(videoID).uploadedBy == request.auth.uid)
                      : getVideoData(videoID).uploadedBy == request.auth.uid);

      // Write: any authenticated user who can read the parent video
      allow create: if isAuthenticated()
                    && request.resource.data.userID == request.auth.uid
                    && ('sharedFolderID' in getVideoData(videoID)
                        ? canAccessFolder(getVideoData(videoID).sharedFolderID)
                        : getVideoData(videoID).uploadedBy == request.auth.uid);
    }

    // ========================================================================
    // APP CONFIG (force update, What's New — read-only for clients)
    // ========================================================================

    match /appConfig/{docID} {
      allow read: if isAuthenticated();
    }

    // ========================================================================
    // COACH SESSIONS
    // ========================================================================

    match /coachSessions/{sessionID} {
      allow read: if isAuthenticated()
                  && resource.data.coachID == request.auth.uid;
      allow create: if isAuthenticated()
                    && request.resource.data.coachID == request.auth.uid
                    && hasCoachTier();
      allow update: if isAuthenticated()
                    && resource.data.coachID == request.auth.uid;
      allow delete: if isAuthenticated()
                    && resource.data.coachID == request.auth.uid;
    }

    // ========================================================================
    // INVITATIONS
    // ========================================================================

    match /invitations/{invitationID} {
      // Any party to an invitation can read it (sender or recipient).
      // Expiration is enforced on updates (accept/decline), not reads —
      // this also avoids the request.time vs client-timestamp mismatch
      // that causes "insufficient permissions" on list queries.
      allow read: if isAuthenticated() && (
        resource.data.athleteID == request.auth.uid ||
        (resource.data.coachEmail == request.auth.token.email && request.auth.token.email_verified == true) ||
        resource.data.coachID == request.auth.uid ||
        (resource.data.athleteEmail == request.auth.token.email && request.auth.token.email_verified == true)
      );

      // Athlete-to-coach invitation: athlete creates, must have Pro tier
      // Coach-to-athlete invitation: coach creates, must have a coach tier
      // Email fields are validated to prevent impersonation
      allow create: if isAuthenticated()
                    && request.resource.data.keys().hasAll(['expiresAt', 'type', 'status'])
                    && request.resource.data.status == 'pending'
                    && isInvitationNotExpired(request.resource.data.expiresAt)
                    && isExpirationInRange(request.resource.data.expiresAt)
                    && (
                      // Athlete-to-coach: athlete is the sender, validate sender identity
                      // folderID/folderName are optional — folders are created server-side on acceptance
                      (request.resource.data.type == "athlete_to_coach"
                       && request.resource.data.athleteID == request.auth.uid
                       && request.resource.data.keys().hasAll(['athleteID', 'coachEmail'])
                       && hasProTier())
                      ||
                      // Coach-to-athlete: coach is the sender, validate sender identity
                      (request.resource.data.type == "coach_to_athlete"
                       && request.resource.data.coachID == request.auth.uid
                       && request.resource.data.coachEmail == request.auth.token.email
                       && request.resource.data.keys().hasAll(['coachID', 'coachEmail', 'athleteEmail', 'athleteName'])
                       && hasCoachTier())
                    );

      // Sender can cancel; recipient can accept/decline — only while not expired.
      // Field-level restrictions prevent privilege escalation (e.g. swapping folderID).
      // Role-based: senders can only cancel; recipients can accept/decline.
      // Status must currently be 'pending' — prevents re-accepting cancelled/declined invitations.
      allow update: if isAuthenticated()
                    && resource.data.status == 'pending'
                    && isInvitationNotExpired(resource.data.expiresAt)
                    // Email-tracking fields (emailSent, emailSentAt, emailError,
                    // emailResentAt) are omitted — those are written by Cloud Functions
                    // via the admin SDK, which bypasses security rules.
                    // folderID/folderName are written by the athlete's client after
                    // creating the folder, so they must remain in the allowed set.
                    // The Cloud Function reads folderID from the invitation at acceptance
                    // time via admin SDK, which bypasses these rules.
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['status', 'acceptedAt', 'declinedAt', 'cancelledAt',
                                 'acceptedByCoachID',
                                 'athleteUserID', 'folderID', 'folderName',
                                 'rejectedReason'])
                    && (
                      // Athlete-to-coach flow:
                      //   Athlete (sender) can ONLY cancel
                      (resource.data.type == "athlete_to_coach"
                       && resource.data.athleteID == request.auth.uid
                       && request.resource.data.status in ['cancelled']) ||
                      //   Coach (recipient) can accept or decline
                      (resource.data.type == "athlete_to_coach"
                       && resource.data.coachEmail == request.auth.token.email
                       && request.auth.token.email_verified == true
                       && request.resource.data.status in ['accepted', 'declined']) ||
                      // Coach-to-athlete flow:
                      //   Coach (sender) can ONLY cancel
                      (resource.data.type == "coach_to_athlete"
                       && resource.data.coachID == request.auth.uid
                       && request.resource.data.status in ['cancelled']) ||
                      //   Athlete (recipient) can accept or decline
                      (resource.data.type == "coach_to_athlete"
                       && resource.data.athleteEmail == request.auth.token.email
                       && request.auth.token.email_verified == true
                       && request.resource.data.status in ['accepted', 'declined'])
                    );

      // Only the sender can delete
      allow delete: if isAuthenticated()
                    && (resource.data.athleteID == request.auth.uid
                        || resource.data.coachID == request.auth.uid);
    }

    // ========================================================================
    // DENY ALL OTHER COLLECTIONS
    // ========================================================================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
